{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn app:app -b 0.0.0.0:$PORT -w 1 --timeout 120 --preload",
    "restartPolicyType": "ON_FAILURE"
  }
}
